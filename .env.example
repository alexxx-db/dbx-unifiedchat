# Databricks Configuration
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi1234567890abcdef

# Unity Catalog Configuration
CATALOG_NAME=yyang
SCHEMA_NAME=multi_agent_genie

# LLM Endpoint
LLM_ENDPOINT=databricks-claude-sonnet-4-5

# Vector Search Configuration
VECTOR_SEARCH_FUNCTION=yyang.multi_agent_genie.search_genie_spaces
VS_ENDPOINT_NAME=genie_multi_agent_vs
EMBEDDING_MODEL=databricks-gte-large-en

# Table Metadata Enrichment
SAMPLE_SIZE=100
MAX_UNIQUE_VALUES=50

# Genie space ids
genie_ids=01f0956a54af123e9cd23907e8167df9,01f0956a387714969edde65458dcc22a,01f0956a4b0512e2a8aa325ffbac821b

# Genie Exports
GENIE_EXPORTS_VOLUME=yyang.multi_agent_genie.volume

# Pipeline Configuration
PIPELINE_TYPE=TRIGGERED
ENRICHED_DOCS_TABLE=yyang.multi_agent_genie.enriched_genie_docs

# Model Serving
MODEL_NAME=multi_agent_genie_system
ENDPOINT_NAME=multi-agent-genie-endpoint
WORKLOAD_SIZE=Small

# Lakebase Configuration (for State Management)
# Create instance in: SQL Warehouses -> Lakebase Postgres -> Create database instance
LAKEBASE_INSTANCE_NAME=agent-state-db
LAKEBASE_EMBEDDING_ENDPOINT=databricks-gte-large-en
LAKEBASE_EMBEDDING_DIMS=1024
